#!/bin/sh

MODULE_DIR=/oem/usr/ko

disable_usb_autosuspend() {
  find /sys/bus/usb/devices -path '*/power/control' -type f 2>/dev/null | while IFS= read -r path; do
    echo on > "${path}" 2>/dev/null || true
  done
}

load_module() {
  mod_name=$1
  file_name=$2

  [ -d /sys/module/"${mod_name}" ] && return 0
  [ -f "${MODULE_DIR}/${file_name}" ] || return 0
  insmod "${MODULE_DIR}/${file_name}" >/dev/null 2>&1 || true
}

start() {
  [ -d "${MODULE_DIR}" ] || return 0

  load_module aes_generic aes_generic.ko
  load_module gf128mul gf128mul.ko
  load_module ghash_generic ghash-generic.ko
  load_module ctr ctr.ko
  load_module ccm ccm.ko
  load_module libarc4 libarc4.ko
  load_module cfg80211 cfg80211.ko
  load_module mac80211 mac80211.ko
  load_module ath ath.ko
  load_module ath9k_hw ath9k_hw.ko
  load_module ath9k_common ath9k_common.ko
  load_module ath9k_htc ath9k_htc.ko

  disable_usb_autosuspend

  if command -v iw >/dev/null 2>&1; then
    iw reg set US >/dev/null 2>&1 || true
  fi

  if [ -d /sys/class/net/wlan0 ] && command -v ip >/dev/null 2>&1; then
    ip link set wlan0 up >/dev/null 2>&1 || true
  fi
}

stop() {
  :
}

case "${1:-}" in
  start|restart)
    start
    ;;
  stop)
    stop
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac
