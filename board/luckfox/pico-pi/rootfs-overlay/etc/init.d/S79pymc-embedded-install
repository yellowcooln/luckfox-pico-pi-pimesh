#!/bin/sh

DEFAULTS="/etc/default/pymc-embedded-install"
REPEATER_DIR="/root/pyMC_Repeater"
MANAGE_SCRIPT="${REPEATER_DIR}/buildroot-manage.sh"
SERVICE_SCRIPT="/etc/init.d/S80pymc-repeater"
DONE_MARKER="/var/lib/pymc_repeater/.embedded-install-complete"
LOGFILE="/var/log/pymc-embedded-install.log"

[ -r "${DEFAULTS}" ] && . "${DEFAULTS}"

ensure_defaults() {
  if [ -z "${PYMC_NODE_NAME:-}" ]; then
    PYMC_NODE_NAME=$(hostname 2>/dev/null || true)
  fi
  [ -n "${PYMC_NODE_NAME:-}" ] || PYMC_NODE_NAME="luckfox-repeater"

  if [ -z "${PYMC_ADMIN_PASSWORD:-}" ]; then
    PYMC_ADMIN_PASSWORD="luckfox"
  fi

  if [ -z "${PYMC_CORE_LOCAL_DIR:-}" ]; then
    PYMC_CORE_LOCAL_DIR="/root/pyMC_core"
  fi

  if [ -z "${PYMC_SKIP_BUILDROOT_DEP_INSTALL:-}" ]; then
    PYMC_SKIP_BUILDROOT_DEP_INSTALL="1"
  fi
}

already_installed() {
  [ -x "/opt/pymc_repeater/venv/bin/python" ] && [ -x "${SERVICE_SCRIPT}" ]
}

run_install() {
  ensure_defaults
  mkdir -p /var/log /var/lib/pymc_repeater

  env \
    PYMC_SILENT=1 \
    PYMC_NODE_NAME="${PYMC_NODE_NAME}" \
    PYMC_ADMIN_PASSWORD="${PYMC_ADMIN_PASSWORD}" \
    PYMC_BUILDROOT_BOARD="${PYMC_BUILDROOT_BOARD:-}" \
    PYMC_RADIO_PRESET="${PYMC_RADIO_PRESET:-}" \
    PYMC_CORE_LOCAL_DIR="${PYMC_CORE_LOCAL_DIR}" \
    PYMC_SKIP_BUILDROOT_DEP_INSTALL="${PYMC_SKIP_BUILDROOT_DEP_INSTALL}" \
    bash "${MANAGE_SCRIPT}" install >>"${LOGFILE}" 2>&1
}

case "${1:-}" in
  start)
    already_installed && exit 0
    [ -f "${DONE_MARKER}" ] && exit 0
    [ -f "${MANAGE_SCRIPT}" ] || exit 0

    if run_install; then
      : > "${DONE_MARKER}"
    fi
    exit 0
    ;;
  stop|restart|status)
    exit 0
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|status}"
    exit 1
    ;;
esac
