#!/bin/sh

IFACE=${WPA_IFACE:-wlan0}
CONF=${WPA_CONF:-/etc/wpa_supplicant.conf}
PIDFILE=/var/run/wpa_supplicant-${IFACE}.pid

has_real_wifi_config() {
  [ -f "${CONF}" ] || return 1
  grep -q '^[[:space:]]*ssid=' "${CONF}" || return 1
  ! grep -q 'YOUR_WIFI_' "${CONF}"
}

start() {
  [ -d /sys/class/net/"${IFACE}" ] || return 0
  has_real_wifi_config || return 0

  mkdir -p /var/run/wpa_supplicant

  if [ -f "${PIDFILE}" ] && kill -0 "$(cat "${PIDFILE}")" 2>/dev/null; then
    return 0
  fi

  wpa_supplicant -B -P "${PIDFILE}" -i "${IFACE}" -c "${CONF}" >/dev/null 2>&1 || return 0
}

stop() {
  if [ -f "${PIDFILE}" ]; then
    kill "$(cat "${PIDFILE}")" >/dev/null 2>&1 || true
    rm -f "${PIDFILE}"
  fi
}

case "${1:-}" in
  start)
    start
    ;;
  stop)
    stop
    ;;
  restart)
    stop
    start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac
