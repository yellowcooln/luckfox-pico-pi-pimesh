diff --git a/scripts/luckfox_rx_probe.py b/scripts/luckfox_rx_probe.py
new file mode 100644
index 0000000..a417319
--- /dev/null
+++ b/scripts/luckfox_rx_probe.py
@@ -0,0 +1,142 @@
+#!/usr/bin/env python3
+"""Direct SX1262 RX probe for Luckfox-style split-chip boards.
+
+Stops relying on pyMC_Repeater logic and polls the radio directly so we can
+see whether the chip itself ever surfaces RX-related IRQ bits.
+"""
+
+from __future__ import annotations
+
+import argparse
+import logging
+import signal
+import sys
+import time
+
+from pymc_core.hardware.sx1262_wrapper import SX1262Radio
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description="Direct RX probe for SX1262 boards")
+    parser.add_argument("--duration", type=float, default=120.0, help="Probe duration in seconds")
+    parser.add_argument("--frequency", type=int, default=910525000)
+    parser.add_argument("--bandwidth", type=int, default=62500)
+    parser.add_argument("--spreading-factor", type=int, default=7)
+    parser.add_argument("--coding-rate", type=int, default=5)
+    parser.add_argument("--tx-power", type=int, default=22)
+    parser.add_argument("--preamble-length", type=int, default=17)
+    return parser.parse_args()
+
+
+def configure_logging() -> None:
+    logging.basicConfig(
+        level=logging.DEBUG,
+        format="%(asctime)s %(levelname)s %(name)s: %(message)s",
+    )
+
+
+def main() -> int:
+    args = parse_args()
+    configure_logging()
+    log = logging.getLogger("luckfox_rx_probe")
+    stop = False
+
+    def handle_stop(signum, _frame):
+        nonlocal stop
+        log.warning("Received signal %s, stopping probe", signum)
+        stop = True
+
+    signal.signal(signal.SIGINT, handle_stop)
+    signal.signal(signal.SIGTERM, handle_stop)
+
+    radio = SX1262Radio(
+        bus_id=0,
+        cs_id=0,
+        cs_pin=17,
+        cs_gpio_chip=4,
+        reset_pin=22,
+        reset_gpio_chip=1,
+        busy_pin=27,
+        busy_gpio_chip=3,
+        irq_pin=23,
+        irq_gpio_chip=1,
+        txen_pin=20,
+        txen_gpio_chip=1,
+        rxen_pin=21,
+        rxen_gpio_chip=1,
+        gpio_chip=1,
+        use_gpiod_backend=False,
+        use_dio2_rf=False,
+        use_dio3_tcxo=True,
+        dio3_tcxo_voltage=1.8,
+        frequency=args.frequency,
+        bandwidth=args.bandwidth,
+        spreading_factor=args.spreading_factor,
+        coding_rate=args.coding_rate,
+        tx_power=args.tx_power,
+        preamble_length=args.preamble_length,
+    )
+
+    try:
+        radio.set_rx_callback(
+            lambda packet: log.warning("[PROBE] callback RX %d bytes: %s", len(packet), packet.hex())
+        )
+        if not radio.begin():
+            log.error("Radio begin() returned False")
+            return 1
+
+        radio.lora.request(radio.lora.RX_CONTINUOUS)
+        time.sleep(radio.RADIO_TIMING_DELAY)
+        log.warning("Probe started for %.1fs", args.duration)
+        radio._log_rx_diagnostics("probe-start")
+
+        deadline = time.time() + args.duration
+        last_irq = None
+        last_diag = 0.0
+
+        rx_mask = radio._get_rx_irq_mask()
+        while not stop and time.time() < deadline:
+            irq = radio.lora.getIrqStatus()
+            if irq != last_irq or irq != 0:
+                log.warning("[PROBE] IRQ status now 0x%04X", irq)
+                last_irq = irq
+
+            if irq & rx_mask:
+                log.warning("[PROBE] RX-related IRQ detected: 0x%04X", irq)
+                radio._log_rx_diagnostics("probe-rx-irq", irq)
+
+                if irq & radio.lora.IRQ_RX_DONE:
+                    payload_len, start_ptr = radio.lora.getRxBufferStatus()
+                    packet_rssi_dbm, snr_db, signal_rssi_dbm = radio.lora.getSignalMetrics()
+                    payload = bytes(radio.lora.readBuffer(start_ptr, payload_len)) if payload_len > 0 else b""
+                    log.warning(
+                        "[PROBE] RX_DONE len=%d rssi=%s snr=%s signal_rssi=%s data=%s",
+                        payload_len,
+                        packet_rssi_dbm,
+                        snr_db,
+                        signal_rssi_dbm,
+                        payload.hex(),
+                    )
+
+                radio.lora.clearIrqStatus(irq)
+                radio.lora.request(radio.lora.RX_CONTINUOUS)
+
+            now = time.time()
+            if now - last_diag >= 2.0:
+                radio._log_rx_diagnostics("probe-loop", irq)
+                last_diag = now
+
+            time.sleep(0.05)
+
+        radio._log_rx_diagnostics("probe-stop")
+        log.warning("Probe finished")
+        return 0
+    finally:
+        try:
+            radio.cleanup()
+        except Exception as exc:
+            log.warning("Cleanup failed: %s", exc)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
