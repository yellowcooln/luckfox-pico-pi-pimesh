#!/bin/sh
set -eu

if [ -x /usr/sbin/useradd ]; then
  exec /usr/sbin/useradd "$@"
fi

home="/var/empty"
shell="/bin/false"
user=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --home)
      home="$2"
      shift 2
      ;;
    --shell)
      shell="$2"
      shift 2
      ;;
    --system)
      shift
      ;;
    *)
      user="$1"
      shift
      ;;
  esac
done

[ -n "${user}" ] || exit 1

if grep -q "^${user}:" /etc/passwd 2>/dev/null; then
  exit 0
fi

uid=990
gid=990
mkdir -p "${home}"
printf '%s:x:%s:\n' "${user}" "${gid}" >> /etc/group
printf '%s:x:%s:%s::%s:%s\n' "${user}" "${uid}" "${gid}" "${home}" "${shell}" >> /etc/passwd
if [ -f /etc/shadow ]; then
  printf '%s:!:19000:0:99999:7:::\n' "${user}" >> /etc/shadow
fi
