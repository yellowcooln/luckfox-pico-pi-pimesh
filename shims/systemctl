#!/bin/sh
set -eu

SERVICE_DIR="/etc/systemd/system"
SERVICE_NAME="${2:-pymc-repeater}"
SERVICE_NAME="${SERVICE_NAME%.service}"
SERVICE_FILE="${SERVICE_DIR}/${SERVICE_NAME}.service"
PID_FILE="/var/run/${SERVICE_NAME}.pid"
LOG_FILE="/var/log/pymc_repeater/service.log"

mkdir -p /var/run "$(dirname "${LOG_FILE}")"

service_exists() {
  [ -f "${SERVICE_FILE}" ]
}

service_pid() {
  if [ -f "${PID_FILE}" ]; then
    cat "${PID_FILE}"
    return 0
  fi
  return 1
}

is_active() {
  if pid=$(service_pid 2>/dev/null) && kill -0 "${pid}" >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

service_workdir() {
  if [ -f "${SERVICE_FILE}" ]; then
    sed -n 's/^WorkingDirectory=//p' "${SERVICE_FILE}" | head -n 1
    return
  fi
  echo "/var/lib/pymc_repeater"
}

service_execstart() {
  if [ -f "${SERVICE_FILE}" ]; then
    sed -n 's/^ExecStart=//p' "${SERVICE_FILE}" | head -n 1
    return
  fi
  echo "/opt/pymc_repeater/venv/bin/python -m repeater.main --config /etc/pymc_repeater/config.yaml"
}

service_start() {
  if is_active; then
    return 0
  fi

  workdir=$(service_workdir)
  execstart=$(service_execstart)
  mkdir -p "${workdir}" "$(dirname "${LOG_FILE}")"

  (
    cd "${workdir}"
    nohup sh -c "exec ${execstart}" >> "${LOG_FILE}" 2>&1 &
    echo "$!" > "${PID_FILE}"
  )
}

service_stop() {
  if ! is_active; then
    rm -f "${PID_FILE}"
    return 0
  fi

  pid=$(service_pid)
  kill "${pid}" >/dev/null 2>&1 || true
  sleep 1
  if kill -0 "${pid}" >/dev/null 2>&1; then
    kill -9 "${pid}" >/dev/null 2>&1 || true
  fi
  rm -f "${PID_FILE}"
}

cmd="${1:-}"
case "${cmd}" in
  daemon-reload|enable|disable)
    exit 0
    ;;
  list-unit-files)
    if service_exists; then
      printf '%s.service enabled\n' "${SERVICE_NAME}"
    fi
    exit 0
    ;;
  start)
    service_start
    ;;
  stop)
    service_stop
    ;;
  restart)
    service_stop
    service_start
    ;;
  is-active)
    if is_active; then
      exit 0
    fi
    exit 3
    ;;
  is-enabled)
    if service_exists; then
      exit 0
    fi
    exit 1
    ;;
  status)
    if is_active; then
      printf '%s is active\n' "${SERVICE_NAME}"
      exit 0
    fi
    printf '%s is inactive\n' "${SERVICE_NAME}"
    exit 3
    ;;
  *)
    echo "[buildroot systemctl shim] unsupported command: ${cmd}" >&2
    exit 0
    ;;
esac
