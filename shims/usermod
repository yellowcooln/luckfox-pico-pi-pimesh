#!/bin/sh
set -eu

if [ -x /usr/sbin/usermod ]; then
  exec /usr/sbin/usermod "$@"
fi

groups=""
user=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    -a)
      shift
      ;;
    -G)
      groups="$2"
      shift 2
      ;;
    *)
      user="$1"
      shift
      ;;
  esac
done

[ -n "${groups}" ] || exit 0
[ -n "${user}" ] || exit 0

old_ifs=${IFS}
IFS=,
set -- ${groups}
IFS=${old_ifs}

for group_name in "$@"; do
  if ! grep -q "^${group_name}:" /etc/group 2>/dev/null; then
    continue
  fi
  current_line=$(grep "^${group_name}:" /etc/group)
  members=$(printf '%s' "${current_line}" | cut -d: -f4)
  case ",${members}," in
    *,"${user}",*)
      continue
      ;;
  esac
  if [ -n "${members}" ]; then
    new_members="${members},${user}"
  else
    new_members="${user}"
  fi
  old_line_escaped=$(printf '%s\n' "${current_line}" | sed 's/[].[^$\\*]/\\&/g')
  sed -i "s/^${old_line_escaped}\$/${group_name}:x:$(printf '%s' "${current_line}" | cut -d: -f3):${new_members}/" /etc/group
done
